# ─── Client (Vite) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server-side (Supabase Edge Functions) ─────────────────────────────
# Set via: npx supabase secrets set KEY=value
# These never reach the client.

# Anthropic — used by ai-chat, scrape-recipe, generate-meal-plan, plan-event,
# get-recipe, nlp-action, and the new meal-engine function (slot-based v2 planner).
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (subscription billing — optional, mock fallback if absent)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Kroger (grocer integration — optional, feature-flagged)
KROGER_CLIENT_ID=...
KROGER_CLIENT_SECRET=...

# NOTE: The meal-engine function uses Claude's built-in web_search_20250305 tool,
# so no Brave/SerpAPI key is required. Web search is included in Anthropic's pricing.
